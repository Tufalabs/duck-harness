From 5c1b6492703f568cafb404e405cb78e24c80182f Mon Sep 17 00:00:00 2001
From: Jay Pankaj Patel <018270239@coe-hpc1.sjsuad.sjsu.edu>
Date: Wed, 8 Jul 2026 22:05:00 -0700
Subject: [PATCH] Install local sources from the uv cache before hitting the
 index

install-local-sources rebuilds tufa-arc-agi-framework with build
isolation, so uv resolves the setuptools build requirement against
pypi.org even when the wheel is already cached. On coe-hpc3 and the
compute nodes, which have no internet, that resolution hangs and then
fails, taking `make sbatch` down with it.

Try the install with --offline first and only fall back to the index
when the cache cannot satisfy the build.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 ARC3-Inference/Makefile | 10 ++++++++--
 1 file changed, 8 insertions(+), 2 deletions(-)

diff --git a/ARC3-Inference/Makefile b/ARC3-Inference/Makefile
index 64487a0..e81e807 100644
--- a/ARC3-Inference/Makefile
+++ b/ARC3-Inference/Makefile
@@ -243,9 +243,15 @@ install-local-sources:
 		exit 1; \
 	fi
 	@if [ -d "$(REPO_ROOT)/../tufa-arc-agi-framework" ]; then \
-		$(UV) pip install --python "$(REPO_ROOT)/.venv/bin/python" \
+		if ! $(UV) pip install --offline --python "$(REPO_ROOT)/.venv/bin/python" \
 			--no-deps \
-			-e "$(REPO_ROOT)/../tufa-arc-agi-framework"; \
+			-e "$(REPO_ROOT)/../tufa-arc-agi-framework"; then \
+			echo "Offline editable install failed; retrying against the package index."; \
+			echo "This needs a host with internet; coe-hpc3 and the compute nodes have none."; \
+			$(UV) pip install --python "$(REPO_ROOT)/.venv/bin/python" \
+				--no-deps \
+				-e "$(REPO_ROOT)/../tufa-arc-agi-framework"; \
+		fi; \
 	fi
 
 prepare-ci:
