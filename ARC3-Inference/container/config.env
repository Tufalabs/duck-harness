#!/usr/bin/env bash
# Central configuration for the ARC3 vLLM Apptainer runtime.
#
# Override any value by exporting it before running a script, or by editing this
# file. Large artifacts default to .cache/ so they stay out of git.

CONTAINER_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$CONTAINER_ROOT/.." && pwd)"

# --- Model -----------------------------------------------------------------
MODEL_ID="${MODEL_ID:-vrfai/Qwen3.6-27B-FP8}"
SERVED_NAME="${SERVED_NAME:-vrfai/Qwen3.6-27B-FP8}"

# --- Shared storage for image and model weights ----------------------------
VLLM_CONTAINER_STORE="${VLLM_CONTAINER_STORE:-$PROJECT_ROOT/.cache/vllm-container}"
SIF_PATH="${SIF_PATH:-$VLLM_CONTAINER_STORE/vllm-openai.sif}"
IMAGE_TAR="${IMAGE_TAR:-$VLLM_CONTAINER_STORE/vllm-openai.tar}"
HF_HOME="${HF_HOME:-$VLLM_CONTAINER_STORE/hf}"

# --- Container image --------------------------------------------------------
VLLM_IMAGE="${VLLM_IMAGE:-vllm/vllm-openai:latest}"

# --- Server ----------------------------------------------------------------
PORT="${PORT:-1234}"
HOST="${HOST:-127.0.0.1}"

# --- vLLM tuning ------------------------------------------------------------
TP="${TP:-1}"
MAX_MODEL_LEN="${MAX_MODEL_LEN:-32768}"
GPU_MEM_UTIL="${GPU_MEM_UTIL:-0.92}"
MAX_NUM_SEQS="${MAX_NUM_SEQS:-}"
DTYPE="${DTYPE:-auto}"
QUANTIZATION="${QUANTIZATION:-}"
KV_CACHE_DTYPE="${KV_CACHE_DTYPE:-}"
TOOL_CALL_PARSER="${TOOL_CALL_PARSER:-qwen3_coder}"
REASONING_PARSER="${REASONING_PARSER:-qwen3}"
VLLM_ATTENTION_BACKEND="${VLLM_ATTENTION_BACKEND:-FLASHINFER}"
MAX_IMAGES="${MAX_IMAGES:-4}"
MAX_VIDEOS="${MAX_VIDEOS:-0}"
EXTRA_ARGS="${EXTRA_ARGS:-}"
