# Build adjacency graph
from collections import deque

def bfs(start, end):
    visited = {start}
    queue = deque([(start, [])])
    while queue:
        (r, c), path = queue.popleft()
        if (r, c) == end:
            return path
        for dr, dc, move in [(-1, 0, 'UP'), (1, 0, 'DOWN'), (0, -1, 'LEFT'), (0, 1, 'RIGHT')]:
            nr, nc = r + dr, c + dc
            if (nr, nc) in walkable and (nr, nc) not in visited:
                visited.add((nr, nc))
                queue.append(((nr, nc), path + [move]))
    return None

if player_pos and goal_pos:
