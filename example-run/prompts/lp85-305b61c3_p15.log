def get_block_map(frame):
    seg = frame.segmentation
    blocks = {}
    for n in seg['nodes']:
        if n['pixels'] == 4:
            b = n['boundary']
            center_r = sum(p[0] for p in b) // len(b)
            center_c = sum(p[1] for p in b) // len(b)
            blocks[(center_r, center_c)] = n['color']
    return blocks

