seg = current_frame.segmentation
green_nodes = [n for n in seg['nodes'] if n['color'] == 'N']

# Get positions sorted by column
green_positions = []
for n in green_nodes:
    b = n['boundary']
    rows = [p[0] for p in b]
    cols = [p[1] for p in b]
    center_row = (min(rows) + max(rows)) // 2
    center_col = (min(cols) + max(cols)) // 2
    green_positions.append((center_col, center_row))

green_positions.sort()
print(f"Green positions (sorted by col): {green_positions}")

# Click green blocks column by column (2 per column: top then bottom)
# Stop before game over (max 7 clicks)
clicks = 0
for col, row in green_positions:
    if clicks >= 7:
        print(f"Stopping at {clicks} clicks to avoid game over")
        break
    result = action([{'action': 'MOUSE', 'row': row, 'col': col}])
    clicks += 1
    seg = current_frame.segmentation
    green_count = sum(1 for n in seg['nodes'] if n['color'] == 'N')
    go = last_action_result.get('game_over', False)
    lc = last_action_result.get('level_completed', False)
    print(f"Clicked ({row},{col}) -> green={green_count}, go={go}, lc={lc}")
    if go or lc:
        print(f"Game over or level completed!")
        break
