        adj_dict[i] = []
    if j not in adj_dict:
        adj_dict[j] = []
    adj_dict[i].append(j)
    adj_dict[j].append(i)

# BFS from player to goal
from collections import deque
queue = deque([(player_id, [player_id])])
visited = {player_id}
path = None
while queue:
    node, p = queue.popleft()
    if node == goal_id:
        path = p
        break
    for neighbor in adj_dict.get(node, []):
        if neighbor not in visited:
