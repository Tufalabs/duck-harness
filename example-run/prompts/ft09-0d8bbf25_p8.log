# Check current grid
seg = current_frame.segmentation
nodes = seg['nodes']

grid = {}
for n in nodes:
    if n['color'] in ['R', 'O'] and n['pixels'] == 36:
        boundary = n['boundary']
        r_min = min(p[0] for p in boundary)
        c_min = min(p[1] for p in boundary)
        row_idx = (r_min - 4) // 8
        col_idx = (c_min - 12) // 8
        grid[(row_idx, col_idx)] = n['color']

print("Current grid:")
for row in range(7):
    row_str = ""
    for col in range(5):
        if (row, col) in grid:
            row_str += grid[(row, col)] + " "
        elif row == 1 and col == 2:
            row_str += "_ "
        elif row == 3 and col in [1, 3]:
            row_str += "_ "
        elif row == 5 and col == 2:
            row_str += "_ "
