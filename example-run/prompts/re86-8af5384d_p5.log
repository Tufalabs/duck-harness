def find_player(seg):
    for node in seg['nodes']:
        if node['color'] == 'W' and node['pixels'] == 1:
            return (node['boundary'][0][0], node['boundary'][0][1])
    return None

def get_targets(seg):
    targets = []
    for node in seg['nodes']:
        if node['pixels'] == 8 and node['color'] == 'c':
            b = node['boundary']
            center = (sum(p[0] for p in b)/len(b), sum(p[1] for p in b)/len(b))
            child_color = None
            for cid in node['children']:
                child = seg['nodes'][cid]
                child_color = child['color']
            targets.append((center, child_color))
    return targets

