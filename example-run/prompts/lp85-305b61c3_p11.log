def get_all_state(frame):
    nodes = frame.segmentation['nodes']
    result = {'upper_top': [], 'upper_left': [], 'upper_right': [], 
              'lower_top': [], 'lower_bottom': [], 'lower_left': [], 'lower_right': []}
    
