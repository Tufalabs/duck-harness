# Explore upper frame state space by clicking R@17,20 multiple times
# Track all states and check for matches

def get_state(frame):
    nodes = frame.segmentation['nodes']
    result = {'upper_top': [], 'upper_left': [], 'upper_right': [], 
              'lower_top': [], 'lower_bottom': [], 'lower_left': [], 'lower_right': []}
    
    for n in nodes:
        b = n['boundary']
        r = (min(p[0] for p in b), max(p[0] for p in b))
        c = (min(p[1] for p in b), max(p[1] for p in b))
        center_r = (r[0] + r[1]) // 2
        center_c = (c[0] + c[1]) // 2
        
        if center_r == 17 and 20 <= center_c <= 39:
            result['upper_top'].append((center_c, n['color']))
        elif center_c == 23 and 20 <= center_r <= 23:
            result['upper_left'].append((center_r, n['color']))
        elif center_c == 35 and 20 <= center_r <= 23:
            result['upper_right'].append((center_r, n['color']))
        elif center_r == 26 and 17 <= center_c <= 44:
            result['lower_top'].append((center_c, n['color']))
        elif center_r == 35 and 17 <= center_c <= 44:
            result['lower_bottom'].append((center_c, n['color']))
        elif center_c == 23 and 29 <= center_r <= 41:
            result['lower_left'].append((center_r, n['color']))
        elif center_c == 35 and 29 <= center_r <= 41:
            result['lower_right'].append((center_r, n['color']))
    
    for k in result:
        result[k].sort()
        result[k] = [c for _, c in result[k]]
    return result

def check_matches(state):
    """Check for various matching patterns"""
    matches = []
    
    # Top vs bottom (excluding c)
    top = [c for c in state['lower_top'] if c != 'c']
    bottom = [c for c in state['lower_bottom'] if c != 'c']
    
    def rotations(lst):
        return [tuple(lst[i:] + lst[:i]) for i in range(len(lst))]
    
    top_rots = set(rotations(top))
    bottom_rots = set(rotations(bottom))
    if top_rots & bottom_rots:
        matches.append(f"TOP==BOTTOM: {list(top_rots & bottom_rots)[0]}")
    
    # Top vs reversed bottom
    bottom_rev = bottom[::-1]
    bottom_rev_rots = set(rotations(bottom_rev))
    if top_rots & bottom_rev_rots:
        matches.append(f"TOP==REV_BOTTOM: {list(top_rots & bottom_rev_rots)[0]}")
    
    # Left vs right (excluding c)
    left = state['lower_left']
    right = [c for c in state['lower_right'] if c != 'c']
    
    left_rots = set(rotations(left))
    right_rots = set(rotations(right))
    if left_rots & right_rots:
        matches.append(f"LEFT==RIGHT: {list(left_rots & right_rots)[0]}")
    
    # Left vs reversed right
    right_rev = right[::-1]
    right_rev_rots = set(rotations(right_rev))
    if left_rots & right_rev_rots:
        matches.append(f"LEFT==REV_RIGHT: {list(left_rots & right_rev_rots)[0]}")
    
    # Upper left vs upper right
    ul = state['upper_left']
    ur = state['upper_right']
    ul_rots = set(rotations(ul))
    ur_rots = set(rotations(ur))
    if ul_rots & ur_rots:
        matches.append(f"UL==UR: {list(ul_rots & ur_rots)[0]}")
    
    ul_rev = ul[::-1]
    ul_rev_rots = set(rotations(ul_rev))
    if ul_rev_rots & ur_rots:
        matches.append(f"REV_UL==UR: {list(ul_rev_rots & ur_rots)[0]}")
    
