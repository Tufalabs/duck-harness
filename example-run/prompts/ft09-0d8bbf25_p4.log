# Compute clicks needed (cycle: b->R->O->b)
# b->b: 0, b->O: 2, R->b: 2, R->O: 1, O->b: 1, O->O: 0
def clicks_needed(current, target):
    if current == target: return 0
    cycle = {'b': 'R', 'R': 'O', 'O': 'b'}
    c = current
    steps = 0
    while c != target:
        c = cycle[c]
        steps += 1
    return steps

print("\nClicks needed:")
to_click = []
for k, v in grid_map.items():
    current = grid_cells.get(k, '?')
    desired = target.get(v, '?')
    n = clicks_needed(current, desired)
    if n > 0:
        print(f"  {k} (grid {v}): {current} -> {desired} ({n} clicks)")
        for _ in range(n):
            to_click.append(k)

print(f"\nTotal clicks: {len(to_click)}")
print(f"Cells to click: {to_click}")
