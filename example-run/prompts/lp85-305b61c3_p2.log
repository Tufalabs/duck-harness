# Compare before and after frames to see what changed
before = last_transition.before_frame
after = last_transition.after_frame

# Get segmentation for both
before_seg = before.segmentation
after_seg = after.segmentation

# Build position->color maps for 4-pixel blocks
def get_blocks(seg):
    blocks = {}
    for n in seg['nodes']:
        if n['pixels'] == 4 and n['color'] not in ['R', 'N', 'B', 'G', 'c']:
            rows = [p[0] for p in n['boundary']]
            cols = [p[1] for p in n['boundary']]
            pos = (min(rows), min(cols))
            blocks[pos] = n['color']
    return blocks

before_blocks = get_blocks(before_seg)
after_blocks = get_blocks(after_seg)

# Find changes
changed = []
for pos in set(list(before_blocks.keys()) + list(after_blocks.keys())):
    bc = before_blocks.get(pos, '-')
    ac = after_blocks.get(pos, '-')
    if bc != ac:
        changed.append((pos, bc, ac))

print(f"Changed positions ({len(changed)}):")
for pos, bc, ac in sorted(changed):
    print(f"  {pos}: {bc} -> {ac}")

# Also check yellow block positions
print("\nYellow blocks before:", [pos for pos, c in before_blocks.items() if c == 'Y'])
print("Yellow blocks after:", [pos for pos, c in after_blocks.items() if c == 'Y'])
