def get_pink_at(frame, col):
    for n in frame.segmentation['nodes']:
        if n['color'] == 'B':
            cr = sum(p[0] for p in n['boundary']) // len(n['boundary'])
            cc = sum(p[1] for p in n['boundary']) // len(n['boundary'])
            if 51 <= cr <= 57 and abs(cc - col) < 5:
                return (n['hash'], n['pixels'])
    return None

def find_cursor(frame):
    for n in frame.segmentation['nodes']:
        if n['color'] == 'W':
            b = n['boundary']
            cr = sum(p[0] for p in b) // len(b)
            cc = sum(p[1] for p in b) // len(b)
            if cr >= 40:
                return (cr, cc)
    return None

