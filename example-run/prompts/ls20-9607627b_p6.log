# Build a maze grid and use BFS to find a path
lines = current_frame.ascii.split('\n')
rows = len(lines)
cols = len(lines[0]) if lines else 0

# Create a grid: 0 = open, 1 = wall
grid = []
for i, line in enumerate(lines):
    row = []
    for j, ch in enumerate(line):
        if ch in ('G', 'O', 'b', 'W', 'w', 'Y'):
            row.append(0)  # Open
        else:
            row.append(1)  # Wall
    grid.append(row)

# Block position: rows 40-44, cols 29-33
# The block's center is at row 42, col 31
# Target: white cross at rows 46-48, cols 50-52
# Target center: row 47, col 51

# BFS from block center to target center
from collections import deque

start = (42, 31)
target = (47, 51)

# Check if start and target are open
print(f"Start ({start[0]}, {start[1]}): {'open' if grid[start[0]][start[1]] == 0 else 'wall'}")
print(f"Target ({target[0]}, {target[1]}): {'open' if grid[target[0]][target[1]] == 0 else 'wall'}")

# BFS
queue = deque([(start, [])])
visited = {start}
found_path = None

while queue:
    (r, c), path = queue.popleft()
    if (r, c) == target:
        found_path = path
        break
    for dr, dc, move in [(-1, 0, 'UP'), (1, 0, 'DOWN'), (0, -1, 'LEFT'), (0, 1, 'RIGHT')]:
        nr, nc = r + dr, c + dc
        if 0 <= nr < rows and 0 <= nc < cols and grid[nr][nc] == 0 and (nr, nc) not in visited:
            visited.add((nr, nc))
            queue.append(((nr, nc), path + [move]))

if found_path:
    print(f"Path found: {found_path}")
    print(f"Path length: {len(found_path)}")
else:
    print("No path found!")
