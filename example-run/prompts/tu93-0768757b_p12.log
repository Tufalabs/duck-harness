seg = current_frame.segmentation
nodes = seg['nodes']

# Print all blocks with their positions and colors
blocks = {}
for n in nodes:
    if n['color'] in ('W', 'g', 'b', 'N', 'R') and n['pixels'] >= 8:
        b = n['boundary']
        min_r = min(p[0] for p in b)
        min_c = min(p[1] for p in b)
        blocks[(min_r, min_c)] = n['color']

rows = sorted(set(r for (r, c) in blocks.keys()))
cols = sorted(set(c for (r, c) in blocks.keys()))
row_map = {r: i for i, r in enumerate(rows)}
col_map = {c: i for i, c in enumerate(cols)}

print("Rows:", rows)
print("Cols:", cols)
print()

# Print normalized grid
norm_blocks = {}
for (r, c), color in blocks.items():
    norm_blocks[(row_map[r], col_map[c])] = color

for ri in range(len(rows)):
    row_str = ""
    for ci in range(len(cols)):
        if (ri, ci) in norm_blocks:
            row_str += norm_blocks[(ri, ci)]
        else:
            row_str += "."
    print(f"  Row {ri}: {row_str}")

# Check adjacency list
print("\nAdjacency list:")
for adj in seg['adjacency_list']:
    i, j = adj
    ni = nodes[i]
    nj = nodes[j]
    if ni['color'] in ('W', 'g', 'b', 'N', 'R') and ni['pixels'] >= 8:
        if nj['color'] in ('W', 'g', 'b', 'N', 'R') and nj['pixels'] >= 8:
            bi = None
            bj = None
            for (r, c), color in blocks.items():
                if r == min(p[0] for p in ni['boundary']) and c == min(p[1] for p in ni['boundary']):
                    bi = (row_map[r], col_map[c])
                if r == min(p[0] for p in nj['boundary']) and c == min(p[1] for p in nj['boundary']):
                    bj = (row_map[r], col_map[c])
            if bi and bj:
                print(f"  {bi} ({ni['color']}) -- {bj} ({nj['color']})")
