# The grid is not uniform. Let me build it based on 6-pixel spacing.
# Player moves 6 pixels per action.
# From the grid, the main cells are at positions that are multiples of 3 apart.
# Let me identify the walkable cells (W, R, B, N, b) and their positions.

seg = current_frame.segmentation
nodes = seg['nodes']

# Collect all cell positions and colors
cells = {}
for n in nodes:
    b = n['boundary']
    r = min(p[0] for p in b)
    c = min(p[1] for p in b)
    # Skip the magenta bar at the bottom and black background
    if n['color'] in ['M', 'B'] and n['pixels'] > 10:
        continue
    cells[(r, c)] = n['color']

# Filter to only gameplay cells (not the magenta bar or single-pixel decorations)
gameplay_cells = {}
for (r, c), color in cells.items():
    if color in ['W', 'R', 'B', 'N', 'b', 'g', 'c']:
        # Check if this is a main grid cell (3x3 or similar)
        gameplay_cells[(r, c)] = color

# Find player and goal
player = None
goal = None
for (r, c), color in gameplay_cells.items():
    if color == 'b':
        player = (r, c)
    elif color == 'N':
        goal = (r, c)

print(f"Player: {player}")
print(f"Goal: {goal}")

# Build adjacency: from each cell, check 6-pixel moves in 4 directions
adj = {}
for (r, c) in gameplay_cells:
    neighbors = []
    for dr, dc, action in [(-6, 0, 'UP'), (6, 0, 'DOWN'), (0, -6, 'LEFT'), (0, 6, 'RIGHT')]:
        nr, nc = r + dr, c + dc
        if (nr, nc) in gameplay_cells:
            neighbors.append(((nr, nc), action))
    adj[(r, c)] = neighbors

print("\nAdjacency:")
for pos, neighbors in sorted(adj.items()):
    print(f"  {pos} ({gameplay_cells[pos]}): {[(n, a) for n, a in neighbors]}")

# BFS to find path
from collections import deque

def bfs(start, goal, adj):
    queue = deque([(start, [])])
    visited = {start}
    
    while queue:
        pos, path = queue.popleft()
        
        if pos == goal:
            return path
        
        for neighbor, action in adj.get(pos, []):
            if neighbor not in visited:
                visited.add(neighbor)
                queue.append((neighbor, path + [action]))
    
    return None

path = bfs(player, goal, adj)
print(f"\nPath found: {path}")
print(f"Path length: {len(path) if path else 'None'}")

# If no path, try with intermediate cells
if path is None:
    print("\nNo direct path. Trying with intermediate cells...")
    # Maybe the player can move through 'g' cells
    all_walkable = {k: v for k, v in gameplay_cells.items() if v != 'B'}
    adj2 = {}
    for (r, c) in all_walkable:
        neighbors = []
        for dr, dc, action in [(-6, 0, 'UP'), (6, 0, 'DOWN'), (0, -6, 'LEFT'), (0, 6, 'RIGHT')]:
            nr, nc = r + dr, c + dc
            if (nr, nc) in all_walkable:
                neighbors.append(((nr, nc), action))
        adj2[(r, c)] = neighbors
    
    path2 = bfs(player, goal, adj2)
    print(f"Path with intermediates: {path2}")
