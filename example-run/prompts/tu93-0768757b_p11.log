# Check adjacency list
seg = current_frame.segmentation
adj = seg['adjacency_list']
nodes = seg['nodes']

# Build node id to color/position mapping
node_info = {}
for n in nodes:
    if n['color'] != 'B':
        b = n['boundary']
        min_r = min(p[0] for p in b)
        min_c = min(p[1] for p in b)
        node_info[n['id']] = {'color': n['color'], 'pos': (min_r//3, min_c//3), 'hash': n['hash']}

# Print adjacency for W, R, N, b nodes
print("Adjacency for key nodes:")
for a, b_id in adj:
    if a in node_info and b_id in node_info:
        ca = node_info[a]['color']
        cb = node_info[b_id]['color']
        if ca in 'WRNb' or cb in 'WRNb':
            pa = node_info[a]['pos']
            pb = node_info[b_id]['pos']
            print(f"  {a}({ca},{pa}) -- {b_id}({cb},{pb})")

# Check p nodes
p_nodes = [n for n in nodes if n['color'] == 'p']
print(f"\nP (purple) nodes: {len(p_nodes)}")
for n in p_nodes:
    b = n['boundary']
