# Explore position 3 states - cycle through and check each
ascii_lines = current_frame.ascii.split('\n')

def get_symbol_at(lines, row_start, col_start):
    inner = []
    for dr in range(1, 6):
        row = list(lines[row_start + dr][col_start:col_start+7])
        row[0] = '.'
        row[-1] = '.'
        inner_row = ''.join(row[1:-1])
        norm_row = ''
        for ch in inner_row:
            norm_row += 'X' if ch == 'B' else '.'
        inner.append(norm_row)
    return tuple(inner)

top_symbols = [get_symbol_at(ascii_lines, r, c) for r, c in [
    (4, 12), (4, 22), (4, 35), (4, 45),
    (13, 12), (13, 22), (13, 35), (13, 45),
    (22, 12), (22, 22), (22, 35), (22, 45)
]]
sky_syms = [get_symbol_at(ascii_lines, 40, 14 + i * 7) for i in range(5)]

# Collect all states of position 3
states = []
for cycle in range(2):  # 2 cycles to detect repeat
    for _ in range(7):
        ascii_lines = current_frame.ascii.split('\n')
        pink3 = get_symbol_at(ascii_lines, 51, 14 + 3 * 7)
        top_match = [j for j, t in enumerate(top_symbols) if t == pink3]
        sky_match = [j for j, s in enumerate(sky_syms) if s == pink3]
        if top_match or sky_match:
            print(f"State: Top={top_match}, Sky={sky_match}")
            print(f"  {' | '.join(pink3)}")
        states.append(pink3)
        action(['DOWN'])

# Check for duplicates (cycle detection)
unique = []
for s in states:
    if s not in unique:
        unique.append(s)
print(f"\nTotal states: {len(states)}, Unique: {len(unique)}")
print(f"Cycle detected at state {len(unique)}")
