# Track Y positions through all transitions
def get_y_positions(frame):
    seg = frame.segmentation
    y_positions = []
    for n in seg['nodes']:
        if n['color'] == 'Y' and n['pixels'] == 4:
            b = n['boundary']
            r = (b[0][0] + b[2][0]) // 2
            c = (b[0][1] + b[2][1]) // 2
            y_positions.append((r, c))
    return sorted(y_positions)

# Get the initial frame (before any actions on level 2)
# The initial frame is the first frame of level 2
