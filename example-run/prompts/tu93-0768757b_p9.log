    dr = r2 - r1
    dc = c2 - c1
    if dr < 0:
        actions.append('UP')
    elif dr > 0:
        actions.append('DOWN')
    elif dc < 0:
        actions.append('LEFT')
    elif dc > 0:
        actions.append('RIGHT')

print(f"Path: {path}")
