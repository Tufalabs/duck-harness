seg = current_frame.segmentation
nodes = seg['nodes']

# Get positions
def get_pos(nid):
    n = next(n for n in nodes if n['id'] == nid)
    b = n['boundary']
    r = (min(p[0] for p in b) + max(p[0] for p in b)) // 2
    c = (min(p[1] for p in b) + max(p[1] for p in b)) // 2
    return (r, c)

# Path through bottom: 3 -> 6 -> 8 -> 25 -> 27 -> 29 -> 12 -> 14 -> 16 -> 1
