def get_state(seg):
    colors = {}
    for n in seg['nodes']:
        b = n['boundary']
        r_min = min(p[0] for p in b)
        c_min = min(p[1] for p in b)
        if n['pixels'] <= 10 and n['color'] not in ['R', 'N', 'c']:
            colors[(r_min, c_min)] = n['color']
    
    top = tuple(colors.get((17, 23+j*3), '?') for j in range(5)) + (colors.get((20,23), '?'), colors.get((20,35), '?'))
    mid = tuple(colors.get((26, 17+j*3), '?') for j in range(10))
    mid_fix = (colors.get((29,23), '?'), colors.get((29,35), '?'))
    bot = tuple(colors.get((35, 17+j*3), '?') for j in range(10))
    bot_fix = (colors.get((38,23), '?'), colors.get((38,35), '?'), colors.get((41,23), '?'), colors.get((41,35), '?'))
    return {'top': top, 'mid': mid, 'mid_fix': mid_fix, 'bot': bot, 'bot_fix': bot_fix}

