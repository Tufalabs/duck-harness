# Check red 1px objects
curr_seg = current_frame.segmentation
red_1px = [n for n in curr_seg['nodes'] if n['color'] == 'R' and n['pixels'] == 1]
print(f"Red 1px objects: {len(red_1px)}")

# Check for X cross and diamond shapes by looking at red objects with specific pixel counts
# X cross: 2 arms × ~13 pixels each = ~26 pixels total
# Diamond: 4 sides × ~13 pixels each = ~52 pixels total
red_by_px = {}
for n in curr_seg['nodes']:
    if n['color'] == 'R':
        px = n['pixels']
        if px not in red_by_px:
            red_by_px[px] = []
        red_by_px[px].append(n)

for px in sorted(red_by_px.keys()):
    nodes = red_by_px[px]
    if px > 1:
        for n in nodes:
            rows = [p[0] for p in n['boundary']]
            cols = [p[1] for p in n['boundary']]
            print(f"Red {px}px: row {min(rows)}-{max(rows)}, col {min(cols)}-{max(cols)}")
    else:
        print(f"Red 1px: {len(nodes)} objects")

# Player
